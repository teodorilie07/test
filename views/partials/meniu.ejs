<nav class="navbar navbar-expand-lg navbar-tuning" data-testid="navbar-main">
  <div class="container-fluid px-4 px-lg-5">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/" data-testid="brand-link">
      <i class="bi bi-gear-fill" style="color: var(--tuning-primary); font-size: 1.4rem;"></i>
      GARAJ <strong>TUNING</strong>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-main" aria-expanded="false" aria-label="Toggle nav">
      <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav-main">
      <ul class="navbar-nav me-auto ms-lg-4">
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/" data-testid="nav-home">Acasă</a>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle <%= currentPath === '/produse' ? 'active' : '' %>" href="/produse" role="button" data-bs-toggle="dropdown" data-testid="nav-produse">Produse</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/produse" data-testid="menu-cat-all">Toate categoriile</a></li>
            <li><hr class="dropdown-divider"></li>
            <% categorii.forEach(function(c) { %>
              <li>
                <a class="dropdown-item" href="/produse?categorie=<%= encodeURIComponent(c) %>" data-testid="menu-cat-<%= c.toLowerCase() %>">
                  <i class="bi bi-chevron-right me-1" style="color: var(--tuning-primary);"></i><%= c %>
                </a>
              </li>
            <% }); %>
          </ul>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/seturi' ? 'active' : '' %>" href="/seturi" data-testid="nav-seturi">Seturi</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#orar-widget" data-testid="nav-orar">Orar</a>
        </li>
      </ul>

      <div class="d-flex gap-3 align-items-center">
        <!-- Theme switch (Bonus 2) -->
        <div class="theme-switch" data-testid="theme-switch">
          <button data-theme="dark" data-testid="theme-btn-dark" title="Dark Racing" class="active">
            <i class="bi bi-moon-stars-fill"></i>
          </button>
          <button data-theme="industrial" data-testid="theme-btn-industrial" title="Industrial">
            <i class="bi bi-tools"></i>
          </button>
          <button data-theme="light" data-testid="theme-btn-light" title="Light">
            <i class="bi bi-sun-fill"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
</nav>
