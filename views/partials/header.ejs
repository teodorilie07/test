<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : 'Tuning Pro Center' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="/resurse/css/custom.css">
<link rel="stylesheet" href="/resurse/css/componente.css">
<script>
  // Aplicare tema imediata (evita flicker) - default 'light' pentru pastel look
  (function() {
    const t = localStorage.getItem('tuning-theme') || 'light';
    document.documentElement.setAttribute('data-tuning-theme', t);
  })();
</script>
</head>
<body>

<!-- Brand header (deasupra navbarului, ca in referinta) -->
<div class="brand-header">
  <div class="container-fluid px-3 px-lg-4">
    <a href="/" style="text-decoration:none;" data-testid="brand-link">
      <h1 class="brand-title">Tuning Pro Center</h1>
    </a>
    <p class="brand-tagline">
      <i class="bi bi-car-front-fill"></i>
      Pasiune auto dusă la extrem
      <i class="bi bi-gear-fill"></i>
    </p>
  </div>
</div>

<%- include('meniu') %>
