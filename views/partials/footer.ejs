<footer class="section-tuning border-top mt-5" style="background: var(--tuning-surface); padding: 2.5rem 0 1.5rem;">
  <div class="container-fluid px-4 px-lg-5">
    <div class="row g-4">
      <div class="col-lg-4">
        <h5 style="font-family:'Rajdhani',sans-serif; text-transform:uppercase; letter-spacing:0.05em;">
          <i class="bi bi-gear-fill" style="color: var(--tuning-primary);"></i> GARAJ <strong style="color:var(--tuning-primary);">TUNING</strong>
        </h5>
        <p style="color: var(--tuning-text-muted); max-width: 400px;">
          Atelierul tău de performanță auto — piese premium, montaj profesionist, garanție maximă.
        </p>
      </div>
      <div class="col-lg-4">
        <%- include('orar') %>
      </div>
      <div class="col-lg-4">
        <h6 class="text-primary-tuning" style="font-family:'Rajdhani',sans-serif; text-transform:uppercase; letter-spacing:0.05em;">Contact</h6>
        <p style="color: var(--tuning-text-muted); margin-bottom: 0.3rem;">
          <i class="bi bi-geo-alt-fill"></i> Str. Motorului 42, București
        </p>
        <p style="color: var(--tuning-text-muted); margin-bottom: 0.3rem;">
          <i class="bi bi-telephone-fill"></i> +40 750 123 456
        </p>
        <p style="color: var(--tuning-text-muted);">
          <i class="bi bi-envelope-fill"></i> contact@garajtuning.ro
        </p>
      </div>
    </div>
    <hr style="border-color: var(--tuning-border);">
    <div class="text-center" style="color: var(--tuning-text-muted); font-size: 0.85rem;">
      &copy; <%= new Date().getFullYear() %> GARAJ TUNING · Proiect Tehnologii Web · Toate drepturile rezervate.
    </div>
  </div>
</footer>

<!-- Comparison Tray (Bonus 20) -->
<div class="comparison-tray" id="comparison-tray" data-testid="comparison-tray">
  <div class="container-fluid px-3">
    <div class="d-flex align-items-center gap-3 flex-wrap">
      <strong style="font-family:'Rajdhani',sans-serif; text-transform:uppercase; letter-spacing:0.05em;">
        <i class="bi bi-columns-gap"></i> Comparare
      </strong>
      <div class="tray-slot" id="tray-slot-1" data-testid="tray-slot-1"><i class="bi bi-plus-lg text-muted"></i></div>
      <div class="tray-slot" id="tray-slot-2" data-testid="tray-slot-2"><i class="bi bi-plus-lg text-muted"></i></div>
      <button class="btn btn-tuning ms-auto" id="btn-comparare" data-testid="btn-comparare-deschide">
        <span>Compară în fereastră nouă</span>
      </button>
      <button class="btn btn-outline-light btn-sm" id="btn-comparare-reset" data-testid="btn-comparare-reset">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
  </div>
</div>

<!-- Bootstrap 5 Bundle JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- App client JS -->
<script src="/resurse/js/theme.js"></script>
<script src="/resurse/js/comparare.js"></script>
<script src="/resurse/js/oferte.js"></script>
<script src="/resurse/js/produs-sesiune.js"></script>
<% if (typeof pageScript !== 'undefined' && pageScript) { %>
  <script src="<%= pageScript %>"></script>
<% } %>
</body>
</html>
