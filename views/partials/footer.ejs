<footer class="section-tuning" style="margin-top: 2rem; margin-bottom: 3rem;">
  <div class="row g-4">
    <div class="col-lg-4">
      <h5 style="font-family:'Bagel Fat One',cursive; color: var(--tuning-primary);">
        <i class="bi bi-car-front-fill"></i> Tuning Pro Center
      </h5>
      <p style="color: var(--tuning-text-muted); max-width: 400px;">
        Atelierul tău de performanță auto — piese premium, montaj profesionist, garanție maximă.
      </p>
    </div>
    <div class="col-lg-4">
      <%- include('orar') %>
    </div>
    <div class="col-lg-4">
      <div class="anunt-box" data-testid="anunt-box-footer">
        <h5><i class="bi bi-megaphone-fill"></i> Anunțuri</h5>
        <p style="margin: 0;">
          Aducem pe stoc <em>evacuări din titan</em> pentru BMW M4. Grăbește-te!
        </p>
      </div>
      <div style="margin-top: 1rem; color: var(--tuning-text-muted); font-size: 0.9rem;">
        <p style="margin-bottom: 0.3rem;"><i class="bi bi-geo-alt-fill"></i> Str. Motorului 42, București</p>
        <p style="margin-bottom: 0.3rem;"><i class="bi bi-telephone-fill"></i> +40 750 123 456</p>
        <p><i class="bi bi-envelope-fill"></i> contact@tuningprocenter.ro</p>
      </div>
    </div>
  </div>
  <hr style="border-color: var(--tuning-border);">
  <div class="text-center" style="color: var(--tuning-text-muted); font-size: 0.85rem;">
    &copy; <%= new Date().getFullYear() %> Tuning Pro Center · Proiect Tehnologii Web · Toate drepturile rezervate.
  </div>
</footer>

<!-- Comparison Tray (Bonus 20) -->
<div class="comparison-tray" id="comparison-tray" data-testid="comparison-tray">
  <div class="container-fluid px-3">
    <div class="d-flex align-items-center gap-3 flex-wrap">
      <strong style="font-family:'Bagel Fat One',cursive; font-size:1.1rem;">
        <i class="bi bi-columns-gap"></i> Comparare
      </strong>
      <div class="tray-slot" id="tray-slot-1" data-testid="tray-slot-1"><i class="bi bi-plus-lg"></i></div>
      <div class="tray-slot" id="tray-slot-2" data-testid="tray-slot-2"><i class="bi bi-plus-lg"></i></div>
      <button class="btn btn-tuning ms-auto" id="btn-comparare" data-testid="btn-comparare-deschide">
        <span>Compară în fereastră nouă</span>
      </button>
      <button class="btn btn-outline-primary btn-sm" id="btn-comparare-reset" data-testid="btn-comparare-reset">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
  </div>
</div>

<!-- Back to top button (ca in referinta) -->
<button class="back-to-top" id="back-to-top" data-testid="back-to-top" aria-label="Sus" title="Sus">
  <i class="bi bi-arrow-up"></i>
</button>

<!-- Bootstrap 5 Bundle JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- App client JS -->
<script src="/resurse/js/theme.js"></script>
<script src="/resurse/js/comparare.js"></script>
<script src="/resurse/js/oferte.js"></script>
<script src="/resurse/js/produs-sesiune.js"></script>
<script src="/resurse/js/back-to-top.js"></script>
<% if (typeof pageScript !== 'undefined' && pageScript) { %>
  <script src="<%= pageScript %>"></script>
<% } %>
</body>
</html>
