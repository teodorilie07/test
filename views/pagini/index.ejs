<%- include('../partials/header') %>

<!-- HERO soft (fara imagine mare de fundal, box alb cu border) -->
<section class="hero-tuning" data-testid="homepage-hero">
  <span class="badge-hero" data-testid="hero-badge"><i class="bi bi-stars"></i> Atelier certificat performanță</span>
  <h1 class="mt-2 reveal">Performanță <span class="accent">Absolută</span></h1>
  <p class="lead reveal" style="animation-delay:0.1s;">
    Descoperă noile standarde. Aducem inovația sub capotă, oferind modificări care îți taie respirația.
    Facem <a href="/produse?categorie=Motor" data-testid="hero-link-motor">tuning profesional</a> și
    <a href="/produse?categorie=Electronice" data-testid="hero-link-electronice">remapare software</a> pentru performanță extremă.
  </p>
  <div class="d-flex gap-3 mt-3 flex-wrap reveal" style="animation-delay:0.2s;">
    <a href="/produse" class="btn btn-tuning" data-testid="hero-cta-catalog"><span><i class="bi bi-images"></i> Vezi catalogul</span></a>
    <a href="/seturi" class="btn btn-tuning-outline" data-testid="hero-cta-seturi"><span><i class="bi bi-box2-heart"></i> Seturi cu discount</span></a>
  </div>
  <div class="d-flex gap-4 mt-4 flex-wrap reveal" style="animation-delay:0.3s;">
    <div>
      <div style="font-family:'Bagel Fat One',cursive; font-size:1.8rem; color:var(--tuning-primary);">20+</div>
      <small style="color:var(--tuning-text-muted);">Piese premium</small>
    </div>
    <div>
      <div style="font-family:'Bagel Fat One',cursive; font-size:1.8rem; color:var(--tuning-primary);">5</div>
      <small style="color:var(--tuning-text-muted);">Categorii</small>
    </div>
    <div>
      <div style="font-family:'Bagel Fat One',cursive; font-size:1.8rem; color:var(--tuning-primary);">3</div>
      <small style="color:var(--tuning-text-muted);">Pachete complete</small>
    </div>
  </div>
</section>

<!-- Marquee pastel (pastram animatia orizontala Faza 3) -->
<div class="marquee-tuning" data-testid="marquee-anunt">
  <div class="marquee-tuning-track">
    Spoiler Carbon <span class="sep">✦</span> Chip Tuning Stage 1 <span class="sep">✦</span> Jante Forjate R19 <span class="sep">✦</span> Evacuare Inox Sport <span class="sep">✦</span> Sistem HUD OBD2 <span class="sep">✦</span> Kit LED 12000lm <span class="sep">✦</span> Livrare 24-48h <span class="sep">✦</span>
  </div>
</div>

<!-- Produse Noi (Bonus 18) -->
<% if (produseNoi && produseNoi.length) { %>
<section class="section-tuning">
  <h2><i class="bi bi-stars"></i> Nou în atelier</h2>
  <div class="row g-3" data-testid="grid-produse-noi">
    <% produseNoi.forEach(function(p) { %>
      <div class="col-md-6 col-lg-4 col-xl-3"><%- include('../partials/card-produs', { produs: p }) %></div>
    <% }); %>
  </div>
</section>
<% } %>

<!-- Fundal fix cu schimbare imagine (animatie Faza 3 pastrata) -->
<section class="bg-fix-slider" id="bg-slider" data-testid="bg-slider"
  style="background-image: url('https://images.unsplash.com/photo-1494976388531-d1058494cdd8?w=1600&q=85');">
  <div class="container-fluid px-4 py-5">
    <div class="row">
      <div class="col-lg-8 offset-lg-2 text-center reveal">
        <h2 style="font-family:'Bagel Fat One',cursive; font-size: clamp(1.6rem, 3vw, 2.5rem); margin-bottom: 0.7rem;">
          Fiecare piesă crește <span style="color:var(--tuning-secondary);">performanța</span>
        </h2>
        <p style="color: var(--tuning-text); max-width: 700px; margin: 0 auto;">
          Fie că vrei mai multă apăsare aerodinamică sau mai mulți CP la roți — la Tuning Pro Center găsești componenta perfectă și mecanicul care ți-o montează.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Column-count text (Faza 3 pastrata) -->
<section class="section-tuning">
  <h2><i class="bi bi-info-circle-fill"></i> De ce Tuning Pro Center</h2>
  <div class="col-count-block" data-testid="col-count-block">
    <p>Cu peste zece ani de experiență în modificarea autovehiculelor pentru pasionații de performanță, Tuning Pro Center oferă mai mult decât un catalog — oferim expertiza montajului corect, calibrarea la banc și garanția că piesa aleasă funcționează perfect pe mașina ta.</p>
    <p>Colaborăm exclusiv cu producători premium: fibra de carbon vine în ambalaj original, jantele forjate sunt monobloc, iar remapările ECU se fac pe bază de fișier custom generat pe banc.</p>
    <p>Fiecare montaj complex este realizat de mecanici certificați, cu scule specializate și proceduri de siguranță. Punem la dispoziție lift, banc de probă și tester diagnoză multibrand.</p>
  </div>
</section>

<!-- Populare -->
<% if (produsePopulare && produsePopulare.length) { %>
<section class="section-tuning">
  <h2><i class="bi bi-heart-fill"></i> Alege-ți piesa</h2>
  <div class="row g-3" data-testid="grid-produse-populare">
    <% produsePopulare.forEach(function(p) { %>
      <div class="col-md-6 col-lg-4 col-xl-3"><%- include('../partials/card-produs', { produs: p }) %></div>
    <% }); %>
  </div>
  <div class="text-center mt-3">
    <a href="/produse" class="btn btn-tuning" data-testid="btn-catalog-toate"><span>Vezi toate produsele <i class="bi bi-arrow-right"></i></span></a>
  </div>
</section>
<% } %>

<%- include('../partials/footer') %>

<script>
  // Background image slider Faza 3 (animatie pastrata)
  (function() {
    const imgs = [
      'https://images.unsplash.com/photo-1494976388531-d1058494cdd8?w=1600&q=85',
      'https://images.unsplash.com/photo-1600793575654-910699b5e4d4?w=1600&q=85',
      'https://images.unsplash.com/photo-1542377281-73d08e3a10aa?w=1600&q=85',
    ];
    let i = 0;
    const el = document.getElementById('bg-slider');
    if (!el) return;
    setInterval(function() {
      i = (i + 1) % imgs.length;
      el.style.backgroundImage = "url('" + imgs[i] + "')";
    }, 5000);
  })();
</script>
